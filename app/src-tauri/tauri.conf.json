{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diablo",
  "version": "0.1.0",
  "identifier": "dev.diablo.ide",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Diablo",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "fs": {},
    "shell": {
      "open": true
    }
  }
}
